PORT=3000
NODE_ENV=development

# MongoDB
LOCAL_MONGO_URL=mongodb://localhost:27017/sereneverse
MONGO_URL=

# JWT — use separate secrets for access and refresh tokens
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Session
SESSION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLIENT_REDIRECT=https://serene-verse.vercel.app/auth/google/callback

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer (email)
MAIL_HOST=
USER=
PASS=

# Ably (realtime — replaces Socket.IO)
ABLY_API_KEY=

# Anthropic (AI features)
ANTHROPIC_API_KEY=

# Vercel Cron (streak reset protection)
CRON_SECRET=
